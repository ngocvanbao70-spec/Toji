--// TÌM MỤC TIÊU
local function FindTeleTarget()
    if AimTargetName == "" then return nil end
    local name = AimTargetName:lower()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= Player and (p.Name:lower():find(name) or p.DisplayName:lower():find(name)) then
            if p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                if p.Character:FindFirstChild("HumanoidRootPart") then return p end
            end
        end
    end
    return nil
end

--// AIM LOCK
local function GetAimTarget()
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    if AimTargetName ~= "" then
        local namedTarget = FindTeleTarget()
        if namedTarget then return namedTarget end
    end
    
    local rootPos = char.HumanoidRootPart.Position
    local cam = workspace.CurrentCamera
    local camPos = cam.CFrame.Position
    local camLook = cam.CFrame.LookVector
    local best = nil
    local bestScore = -999999
    
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= Player and not AimProtected[plr.Name] and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local head = plr.Character:FindFirstChild("Head")
            if hrp then
                local tp = head and head.Position or (hrp.Position + Vector3.new(0, 2, 0))
                local dist = (hrp.Position - rootPos).Magnitude
                if dist < AIM_RANGE then
                    local dir = (tp - camPos).Unit
                    local angle = math.acos(math.clamp(dir:Dot(camLook), -1, 1))
                    if angle <= math.rad(AIM_FOV) then
                        local score = (2000 - dist) - (math.deg(angle) * 10)
                        if score > bestScore then bestScore = score; best = plr end
                    end
                end
            end
        end
    end
    return best
end

local function AimLockUpdate()
    if not IsAimLock then return end
    
    if AimTarget then
        local valid = false
        if AimTarget.Character and AimTarget.Character:FindFirstChild("Humanoid") and AimTarget.Character.Humanoid.Health > 0 then
            local char = Player.Character
            if char and char:FindFirstChild("HumanoidRootPart") and AimTarget.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (AimTarget.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < AIM_RANGE then valid = true end
            end
        end
        if not valid then AimTarget = nil; AimLastPos = nil end
    end
    
    if not AimTarget then AimTarget = GetAimTarget() end
    
    if AimTarget then
        AimInfo.Text = "🎯 ĐANG QUÉT: " .. AimTarget.DisplayName
        AimInfo.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        AimInfo.Text = "🔍 ĐANG QUÉT..."
        AimInfo.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
    
    if AimTarget and AimTarget.Character then
        local head = AimTarget.Character:FindFirstChild("Head")
        local hrp = AimTarget.Character:FindFirstChild("HumanoidRootPart")
        local hum = AimTarget.Character:FindFirstChild("Humanoid")
        
        local currentPos = head and head.Position or (hrp and hrp.Position + Vector3.new(0, 2, 0))
        if not currentPos then return end
        
        local velocity = Vector3.zero
        if AimLastPos and hrp then
            local dt = 0.016
            if dt > 0 then velocity = (hrp.Position - AimLastPos) / dt end
        end
        if hum and hum.MoveDirection.Magnitude > 0 then
            velocity = hum.MoveDirection * hum.WalkSpeed
        end
        
        local predictedPos = currentPos + (velocity * 0.1)
        workspace.CurrentCamera.CFrame = CFrame.lookAt(workspace.CurrentCamera.CFrame.Position, predictedPos)
        if hrp then AimLastPos = hrp.Position end
    end
end

local function StartAimLock()
    IsAimLock = true; AimTarget = GetAimTarget(); AimLastPos = nil
    if AimConnection then AimConnection:Disconnect() end
    AimConnection = RunService.RenderStepped:Connect(AimLockUpdate)
end

local function StopAimLock()
    IsAimLock = false; AimTarget = nil; AimLastPos = nil
    if AimConnection then AimConnection:Disconnect(); AimConnection = nil end
    AimInfo.Text = "🎯 MỤC TIÊU: Chưa có"; AimInfo.TextColor3 = Color3.fromRGB(200, 200, 200)
end

--// TELEPORT - TẠM TẮT BLOCK 0.3s SAU KHI TELE
local function TeleportToTarget()
    local c = Player.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return end
    local hrp = c.HumanoidRootPart
    
    if not TeleTarget or not TeleTarget.Character or not TeleTarget.Character:FindFirstChild("Humanoid") or TeleTarget.Character.Humanoid.Health <= 0 then
        TeleTarget = FindTeleTarget()
    end
    
    if not TeleTarget and AimTargetName == "" then
        local nearest, nearestDist = nil, 999
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if dist < nearestDist then nearest = p; nearestDist = dist end
            end
        end
        TeleTarget = nearest
    end
    
    if not TeleTarget or not TeleTarget.Character or not TeleTarget.Character:FindFirstChild("HumanoidRootPart") then return end
    local thrp = TeleTarget.Character.HumanoidRootPart
    
    local finalPos = thrp.Position + (-thrp.CFrame.LookVector * 4) + Vector3.new(0, 0, 0)
    if BMode == 2 then finalPos = thrp.Position + (thrp.CFrame.LookVector * 3) + Vector3.new(0, 0, 0)
    elseif BMode == 3 then finalPos = thrp.Position + Vector3.new(0, 5, 0)
    elseif BMode == 4 then
        local angle = math.random() * math.pi * 2
        finalPos = thrp.Position + Vector3.new(math.cos(angle) * 5, 1, math.sin(angle) * 5)
    elseif BMode == 5 then
        local time = tick() * 3
        finalPos = thrp.Position + Vector3.new(math.cos(time) * 5, 1, math.sin(time) * 5)
    end
    
    hrp.CFrame = CFrame.new(finalPos, thrp.Position)
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    for _, v in pairs(c:GetDescendants()) do
        if v:IsA("BasePart") then v.AssemblyLinearVelocity = Vector3.zero; v.AssemblyAngularVelocity = Vector3.zero end
    end
    
    if IsAutoBlock then
        BlockDisabledUntil = tick() + 0.3
    end
end

--// TĂNG TẦM ĐÁNH
local function ExtendReach()
    if not IsReach then return end
    local c = Player.Character; if not c then return end
    local rootPos = c:FindFirstChild("HumanoidRootPart"); if not rootPos then return end
    
    local nearest, nearestDist = nil, ReachDistance
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local dist = (plr.Character.HumanoidRootPart.Position - rootPos.Position).Magnitude
            if dist < nearestDist then nearest = plr; nearestDist = dist end
        end
    end
    
    if nearest and nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart") then
        local thrp = nearest.Character.HumanoidRootPart
        local dir = (rootPos.Position - thrp.Position).Unit
        thrp.CFrame = CFrame.new(rootPos.Position - dir * 3, thrp.Position)
        thrp.AssemblyLinearVelocity = Vector3.zero
    end
end

